generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String          @id @default(cuid())
  email                  String          @unique
  name                   String?
  passwordHash           String
  role                   String          @default("viewer")
  createdAt              DateTime        @default(now())
  accountAccesses        AccountAccess[] @relation("AccountAccessGrantee")
  portadorAliasesGranted PortadorAlias[] @relation("PortadorAliasGrantee")
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  role      String    @default("viewer")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Invoice {
  id           String        @id @default(cuid())
  userId       String?       // owner — quem importou
  accountId    String?       // qual conta este extrato pertence
  account      Account?      @relation(fields: [accountId], references: [id])
  filename     String
  contentHash  String?       @unique
  cardBrand    String?
  cardHolder   String?
  month        String
  uploadedAt   DateTime      @default(now())
  status       String
  transactions Transaction[]

  @@index([userId])
  @@index([accountId])
}

model Purchase {
  id               String        @id @default(cuid())
  userId           String?
  description      String
  purchaseKey      String        @unique
  totalAmount      Float?
  installmentCount Int
  currency         String        @default("BRL")
  cardHolder       String?
  transactions     Transaction[]
  createdAt        DateTime      @default(now())

  @@index([userId])
  @@index([cardHolder])
}

model Category {
  id                    String                 @id @default(cuid())
  userId                String?                // null = categoria padrão do sistema
  name                  String
  kind                  String                 // income | expense | transfer
  isFixed               Boolean                @default(false)
  createdAt             DateTime               @default(now())
  recurringTransactions RecurringTransaction[]

  @@index([userId])
}

model Account {
  id                    String                 @id @default(cuid())
  userId                String
  name                  String
  type                  String                 // checking | savings | credit_card | investment | cash
  institution           String?
  currentBalance        Float                  @default(0)
  currency              String                 @default("BRL")
  creditLimit           Float?
  closingDay            Int?
  dueDay                Int?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  recurringTransactions RecurringTransaction[]
  invoices              Invoice[]
  accesses              AccountAccess[]

  @@index([userId])
}

model AccountAccess {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  granteeId  String
  grantee    User     @relation("AccountAccessGrantee", fields: [granteeId], references: [id], onDelete: Cascade)
  permission String   // "view" | "edit"
  createdAt  DateTime @default(now())

  @@unique([accountId, granteeId])
  @@index([granteeId])
}

model PortadorAlias {
  id            String   @id @default(cuid())
  ownerUserId   String   // owner da conta que criou o mapeamento
  granteeUserId String   // usuário a quem este nome pertence
  grantee       User     @relation("PortadorAliasGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)
  name          String   // string exata do cardHolder no PDF
  createdAt     DateTime @default(now())

  @@unique([ownerUserId, name])
  @@index([granteeUserId])
}

model RecurringTransaction {
  id          String    @id @default(cuid())
  userId      String
  accountId   String?
  account     Account?  @relation(fields: [accountId], references: [id])
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  kind        String    // income | expense
  description String
  amount      Float
  dayOfMonth  Int
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
}

model Transaction {
  id                String    @id @default(cuid())
  userId            String?
  date              DateTime
  description       String
  amount            Float
  currency          String    @default("BRL")
  amountBRL         Float?
  category          String?
  paymentMethod     String
  cardBrand         String?
  cardHolder        String?
  invoiceId         String?
  invoice           Invoice?  @relation(fields: [invoiceId], references: [id])
  source            String
  invoiceMonth      String?
  installmentNumber Int?
  purchaseId        String?
  purchase          Purchase? @relation(fields: [purchaseId], references: [id])
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@index([date])
  @@index([category])
  @@index([invoiceMonth])
  @@index([paymentMethod])
  @@index([currency])
  @@index([cardHolder])
  @@index([purchaseId])
}
