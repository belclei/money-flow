generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String             @id @default(cuid())
  email                  String             @unique
  name                   String?
  nickname               String?
  passwordHash           String
  role                   String             @default("viewer")
  createdAt              DateTime           @default(now())
  accountAccesses        AccountAccess[]    @relation("AccountAccessGrantee")
  creditCardAccesses     CreditCardAccess[] @relation("CreditCardAccessGrantee")
  portadorAliasesGranted PortadorAlias[]    @relation("PortadorAliasGrantee")
}

model Invite {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  role      String    @default("viewer")
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model CreditCard {
  id             String             @id @default(cuid())
  userId         String
  name           String
  institution    String?
  creditLimit    Float?
  closingDay     Int?               // dia de fechamento da fatura
  dueDay         Int                // dia de vencimento (obrigatório)
  currentBill    Float              @default(0) // valor da fatura atual
  currency       String             @default("BRL")
  autoDebit      Boolean            @default(false)
  debitAccountId String?            // conta corrente para débito automático
  debitAccount   Account?           @relation("CreditCardDebitAccount", fields: [debitAccountId], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  invoices       Invoice[]
  accesses       CreditCardAccess[]

  @@index([userId])
  @@index([debitAccountId])
}

model CreditCardAccess {
  id           String     @id @default(cuid())
  creditCardId String
  creditCard   CreditCard @relation(fields: [creditCardId], references: [id], onDelete: Cascade)
  granteeId    String
  grantee      User       @relation("CreditCardAccessGrantee", fields: [granteeId], references: [id], onDelete: Cascade)
  permission   String     // "view" | "edit"
  createdAt    DateTime   @default(now())

  @@unique([creditCardId, granteeId])
  @@index([granteeId])
}

model Invoice {
  id           String      @id @default(cuid())
  userId       String?
  creditCardId String?
  creditCard   CreditCard? @relation(fields: [creditCardId], references: [id])
  filename     String
  contentHash  String?     @unique
  cardBrand    String?
  cardHolder   String?
  month        String
  uploadedAt   DateTime    @default(now())
  status       String
  transactions Transaction[]

  @@index([userId])
  @@index([creditCardId])
}

model Purchase {
  id               String        @id @default(cuid())
  userId           String?
  description      String
  purchaseKey      String        @unique
  totalAmount      Float?
  installmentCount Int
  currency         String        @default("BRL")
  cardHolder       String?
  transactions     Transaction[]
  createdAt        DateTime      @default(now())

  @@index([userId])
  @@index([cardHolder])
}

model Category {
  id                    String                 @id @default(cuid())
  userId                String?
  name                  String
  kind                  String                 // income | expense
  createdAt             DateTime               @default(now())
  recurringTransactions RecurringTransaction[]

  @@index([userId])
}

model Account {
  id                    String                 @id @default(cuid())
  userId                String
  name                  String
  type                  String                 // checking | savings | investment | cash
  institution           String?
  currentBalance        Float                  @default(0)
  limit                 Float?                 // limite de crédito/cheque especial (opcional)
  currency              String                 @default("BRL")
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  recurringTransactions RecurringTransaction[]
  creditCards           CreditCard[]           @relation("CreditCardDebitAccount")
  accesses              AccountAccess[]
  transactions          Transaction[]
  statements            AccountStatement[]

  @@index([userId])
}

model AccountStatement {
  id           String        @id @default(cuid())
  userId       String?
  accountId    String
  account      Account       @relation(fields: [accountId], references: [id])
  filename     String
  contentHash  String?       @unique
  period       String?
  uploadedAt   DateTime      @default(now())
  status       String
  transactions Transaction[]

  @@index([userId])
  @@index([accountId])
}

model AccountAccess {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  granteeId  String
  grantee    User     @relation("AccountAccessGrantee", fields: [granteeId], references: [id], onDelete: Cascade)
  permission String   // "view" | "edit"
  createdAt  DateTime @default(now())

  @@unique([accountId, granteeId])
  @@index([granteeId])
}

model PortadorAlias {
  id            String   @id @default(cuid())
  ownerUserId   String
  granteeUserId String
  grantee       User     @relation("PortadorAliasGrantee", fields: [granteeUserId], references: [id], onDelete: Cascade)
  name          String
  createdAt     DateTime @default(now())

  @@unique([ownerUserId, name])
  @@index([granteeUserId])
}

model RecurringTransaction {
  id          String    @id @default(cuid())
  userId      String
  accountId   String?
  account     Account?  @relation(fields: [accountId], references: [id])
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  kind        String    // income | expense
  description String
  amount      Float
  dayOfMonth  Int
  endDate     DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([accountId])
  @@index([categoryId])
}

model Transaction {
  id                String            @id @default(cuid())
  userId            String?
  date              DateTime
  description       String
  amount            Float
  currency          String            @default("BRL")
  amountBRL         Float?
  category          String?
  paymentMethod     String
  cardBrand         String?
  cardHolder        String?
  invoiceId         String?
  invoice           Invoice?          @relation(fields: [invoiceId], references: [id])
  accountId         String?
  account           Account?          @relation(fields: [accountId], references: [id])
  statementId       String?
  statement         AccountStatement? @relation(fields: [statementId], references: [id])
  source            String
  invoiceMonth      String?
  installmentNumber Int?
  purchaseId        String?
  purchase          Purchase?         @relation(fields: [purchaseId], references: [id])
  createdAt         DateTime          @default(now())

  @@index([userId])
  @@index([date])
  @@index([category])
  @@index([invoiceMonth])
  @@index([paymentMethod])
  @@index([currency])
  @@index([cardHolder])
  @@index([purchaseId])
  @@index([accountId])
  @@index([statementId])
}
